MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/workhub_db?appName=Cluster0

PORT=5000
JWT_SECRET=<replace-with-strong-secret>

VITE_NODE_API_URL=http://localhost:5000
VITE_PYTHON_API_URL=http://localhost:8000

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=<email-user>
EMAIL_PASS=<email-app-password>
FRONTEND_URL=http://localhost:5173

GOOGLE_CLIENT_ID=<google-client-id>
VITE_GOOGLE_CLIENT_ID=<google-client-id>

R2_ACCOUNT_ID=<cloudflare-account-id>
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_BUCKET_NAME=workhub-documents
R2_REGION=auto
MAX_UPLOAD_SIZE_MB=50

CLOUDFLARE_REALTIME_ACCOUNT_ID=<cloudflare-realtime-account-id>
CLOUDFLARE_REALTIME_APP_ID=<cloudflare-realtimekit-app-id>
CLOUDFLARE_REALTIME_API_TOKEN=<cloudflare-realtime-api-token>
CLOUDFLARE_REALTIME_HOST_PRESET=group_call_host
CLOUDFLARE_REALTIME_PARTICIPANT_PRESET=group_call_host
